{
  "name": "goal-tracker-monorepo",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "db:generate": "pnpm --filter @goal-tracker/db db:generate",
    "db:migrate": "pnpm --filter @goal-tracker/db db:migrate",
    "db:migrate:prod": "pnpm --filter @goal-tracker/db db:migrate:prod",
    "db:studio": "pnpm --filter @goal-tracker/db db:studio"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "unrs-resolver"
    ]
  }
}
